<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S3プレサインドURLアップローダー</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: #f5f5f7;
            color: #1d1d1f;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            background-color: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            padding: 40px;
            width: 100%;
            max-width: 500px;
            text-align: center;
        }
        h2 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #000000;
        }
        p {
            font-size: 14px;
            color: #86868b;
            margin-bottom: 30px;
            line-height: 1.5;
        }
        .drop-zone {
            border: 2px dashed #0066cc;
            border-radius: 12px;
            padding: 30px 20px;
            background-color: #f0f6ff;
            cursor: pointer;
            transition: background-color 0.2s, border-color 0.2s;
            margin-bottom: 24px;
        }
        .drop-zone:hover {
            background-color: #e4f0ff;
        }
        .drop-zone__text {
            font-size: 16px;
            font-weight: 500;
            color: #0066cc;
        }
        .file-info {
            display: none;
            margin-top: 15px;
            font-size: 14px;
            color: #1d1d1f;
            word-break: break-all;
            background: #f5f5f7;
            padding: 10px;
            border-radius: 6px;
        }
        input[type="file"] {
            display: none;
        }
        button {
            display: block;
            width: 100%;
            padding: 14px;
            background-color: #0071e3;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        button:hover {
            background-color: #0077ed;
        }
        button:disabled {
            background-color: #aeaeae;
            cursor: not-allowed;
        }
        #status {
            margin-top: 20px;
            font-size: 15px;
            font-weight: 600;
        }
        .success { color: #34c759; }
        .error { color: #ff3b30; }
        .loading { color: #86868b; }
    </style>
</head>
<body>

    <div class="container">
        <h2>S3ファイルアップロード</h2>
        <p>ファイルを選択して、AWS S3バケットへ直接安全にアップロードします。</p>
        
        <div class="drop-zone" onclick="document.getElementById('fileInput').click()">
            <span class="drop-zone__text">📄 ここをクリックしてファイルを選択</span>
            <div id="fileInfo" class="file-info"></div>
            <input type="file" id="fileInput">
        </div>
        
        <button id="uploadBtn" onclick="startUpload()" disabled>アップロードを開始</button>
        <div id="status"></div>
    </div>

    <script>
        const fileInput = document.getElementById('fileInput');
        const fileInfo = document.getElementById('fileInfo');
        const uploadBtn = document.getElementById('uploadBtn');
        const statusDiv = document.getElementById('status');

        // ファイルが選択された時のイベント
        fileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                fileInfo.innerText = `選択中: ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
                fileInfo.style.display = 'block';
                uploadBtn.disabled = false;
                statusDiv.innerText = '';
            } else {
                fileInfo.style.display = 'none';
                uploadBtn.disabled = true;
            }
        });

        // アップロード処理
        async function startUpload() {
            const file = fileInput.files[0];
            if (!file) return;

            // プレースホルダー文字列（Python等でこの部分を置換してください）
            const presignedUrl = "__S3_PRESIGNED_URL_PLACEHOLDER_XYZ__";

            // 万が一置換されていない場合のチェック
            if (presignedUrl.startsWith("__S3_")) {
                alert("エラー: 署名付きURLが正しく設定されていません。HTMLファイル内のテンプレート文字列を置換してください。");
                return;
            }

            // UIの初期化
            uploadBtn.disabled = true;
            statusDiv.className = 'loading';
            statusDiv.innerText = '⏳ アップロード中...';

            try {
                // S3へPUTリクエストを送信
                const response = await fetch(presignedUrl, {
                    method: 'PUT',
                    body: file,
                    headers: {
                        // 必要に応じてヘッダーを追加
                        'Content-Type': file.type
                    }
                });

                if (response.ok) {
                    statusDiv.className = 'success';
                    statusDiv.innerText = '✨ アップロード成功！';
                } else {
                    statusDiv.className = 'error';
                    statusDiv.innerText = `❌ アップロード失敗 (Status: ${response.status})`;
                    console.error('S3 Response:', await response.text());
                }
            } catch (error) {
                statusDiv.className = 'error';
                statusDiv.innerText = '❌ 通信エラー（CORS設定を確認してください）';
                console.error('Fetch Error:', error);
            } finally {
                uploadBtn.disabled = false;
            }
        }
    </script>
</body>
</html>
